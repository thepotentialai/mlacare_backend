# Copier vers .env en local ; en production (O2switch, etc.), préférer les variables
# d’environnement du panneau (« Add Variable » / Setup Python App) plutôt qu’un fichier.

# ─── Production (valeurs alignées sur mlacare/settings.py et le déploiement MLACare) ───
DEBUG=False
# Générer une clé forte : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
ALLOWED_HOSTS=mlacare.mladoctors.org,www.mlacare.mladoctors.org

# Front autorisé (CORS) + origines CSRF (formulaires / admin HTTPS)
CORS_ALLOWED_ORIGINS=https://mlacare.mladoctors.org
CSRF_TRUSTED_ORIGINS=https://mlacare.mladoctors.org

# Base distante (USE_LOCAL_DB=false en prod — obligatoire avec DEBUG=False pour utiliser PG*)
USE_LOCAL_DB=False
PGDATABASE=osiq8274_mlacare_db
PGUSER=osiq8274_user
# Mot de passe : celui du compte PostgreSQL O2switch (ne jamais commiter la valeur réelle dans le dépôt)
PGPASSWORD=
# Hôte/port/SSL : tels qu’indiqués dans le panneau hébergeur (en prod, PGHOST ne doit pas être localhost si votre policy Django l’interdit)
PGHOST=
PGPORT=5432
PGSSLMODE=require
# Optionnel : durée de persistance des connexions (secondes), défaut 60 dans settings
# DB_CONN_MAX_AGE=60

SERVE_MEDIA_VIA_DJANGO=True

# HTTPS / durcissement (optionnel ; des valeurs par défaut s’appliquent déjà si DEBUG=False)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=False

# Email SMTP (OTP, etc.) — mêmes défauts que settings.py
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mladoctors.org
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=assistance@mladoctors.org
# Mot de passe du compte mail (obligatoire pour l’envoi réel — ne pas commiter)
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL="MLACare <assistance@mladoctors.org>"

# PayGate (FLOOZ/TMONEY)
PAYGATE_KEY=
# Callback à configurer dans le dashboard PayGate :
# https://<votre-backend>/api/payments/donations/payment_status/

# ─── Développement local (exemples — commenter ou utiliser un .env séparé) ───
# DEBUG=True
# USE_LOCAL_DB=True
# LOCAL_PGDATABASE=mlacare_db
# LOCAL_PGUSER=postgres
# LOCAL_PGPASSWORD=
# LOCAL_PGHOST=localhost
# LOCAL_PGPORT=5432
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
# Tester sans SMTP :
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
